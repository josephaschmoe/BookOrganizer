rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read and write their own catalog document.
    match /users/{userId}/catalog/data {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Share link token lookup — public read, Admin SDK writes only.
    match /shareLinks/{token} {
      allow read: if true;
      allow write: if false;
    }
  }
}
