rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read and write their own catalog documents.
    match /users/{userId}/catalog/data {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/catalog/research {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-book briefing subcollection — unlimited scale, one doc per book.
    match /users/{userId}/briefings/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-book briefing audio metadata.
    match /users/{userId}/briefingAudio/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/bookPhotos/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/briefingAudioJobs/{jobId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/backupJobs/{backupId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Share link token lookup — public read, Admin SDK writes only.
    match /shareLinks/{token} {
      allow read: if true;
      allow write: if false;
    }
  }
}
